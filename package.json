{
  "name": "entrelinhas",
  "version": "1.0.0",
  "private": true,
  "description": "Backend platform for turning group chat messages into structured business information.",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "db:migrate": "tsx scripts/migrate.ts",
    "dev:worker": "tsx watch src/processing/worker.ts",
    "start": "node dist/src/server.js",
    "start:worker": "node dist/src/processing/worker.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "bullmq": "^5.79.2",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.4.0",
    "pg": "^8.22.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@eslint/js": "^9.30.1",
    "@types/node": "^24.0.10",
    "@types/pg": "^8.20.0",
    "eslint": "^9.30.1",
    "prettier": "^3.6.2",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.35.1",
    "vitest": "^3.2.4"
  }
}
